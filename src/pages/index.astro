---
import Layout from '../layouts/Layout.astro';
import ReelsCarousel from '../components/ReelsCarousel.astro';
import WorkOverlay from '../components/WorkOverlay.astro';
---

<Layout
  title="Christopher Doubleday | Motion Designer"
  description="Motion designer and video editor creating bold, high-energy content for brands."
  scrollSmooth={true}
>
  <>
    <!-- ==============================
         HERO — name + tagline only
    ============================== -->
    <section class="text-center relative pt-8 pb-4">
      <div class="relative z-10">

        <div class="hero-clip">
          <p class="hero-word font-sans text-sm tracking-widest uppercase mb-8" style="animation-delay: 0ms; color: var(--color-accent-blue);">
            Motion Designer & Video Editor
          </p>
        </div>

        <h1 class="font-display tracking-display text-7xl md:text-9xl text-n200 leading-none mb-6 flex flex-wrap justify-center gap-x-6">
          <span class="hero-clip"><span class="hero-word" style="animation-delay: 80ms"><span class="hero-letter">C</span><span class="hero-letter">h</span><span class="hero-letter">r</span><span class="hero-letter">i</span><span class="hero-letter">s</span></span></span>
          <span class="hero-clip"><span class="hero-word" style="animation-delay: 200ms"><span class="hero-letter">D</span><span class="hero-letter">o</span><span class="hero-letter">u</span><span class="hero-letter">b</span><span class="hero-letter">l</span><span class="hero-letter">e</span><span class="hero-letter">d</span><span class="hero-letter">a</span><span class="hero-letter">y</span></span></span>
        </h1>

        <div class="hero-clip">
          <p class="hero-word mt-4 max-w-xl mx-auto text-n500 text-lg leading-relaxed" style="animation-delay: 380ms">
            Bold visuals. Fast edits. Built for brands that demand attention.
          </p>
        </div>

      </div>
    </section>

    <!-- ==============================
         FEATURED — 3D carousel
    ============================== -->
    <section id="featured" class="py-4">
      <ReelsCarousel />
    </section>

    <!-- ==============================
         STICKY SECTION NAV
    ============================== -->
    <div class="sticky top-[72px] z-10 border-y border-white/5 backdrop-blur-md" style="background: color-mix(in srgb, var(--color-bg-base) 90%, transparent);">
      <nav class="container flex items-center justify-center gap-8 md:gap-16 py-4">
        <a href="#featured"  class="section-nav-link" data-section="featured">Featured</a>
        <a href="#showreel"  class="section-nav-link" data-section="showreel">Showreel</a>
        <button             class="section-nav-link" id="nav-work-btn">Work</button>
      </nav>
    </div>

    <!-- ==============================
         SHOWREEL
    ============================== -->
    <section id="showreel" class="py-12 border-t border-white/5">
      <div class="mb-6">
        <div class="reveal-clip"><p class="reveal-word text-sm tracking-widest uppercase mb-3" style="--reveal-delay: 0ms; color: var(--color-accent-blue);">Featured</p></div>
        <div class="reveal-clip"><h2 class="reveal-word font-display tracking-display text-5xl md:text-7xl text-n200" style="--reveal-delay: 120ms">Showreel</h2></div>
        <div class="reveal-clip"><p class="reveal-word text-n500 mt-4 max-w-lg" style="--reveal-delay: 220ms">A full-cut overview of motion design and video editing work across brands and platforms.</p></div>
      </div>

      <div class="w-full max-w-4xl glow overflow-hidden">
        <iframe
          src="https://iframe.mediadelivery.net/embed/635173/b7da40bf-36c4-45d2-9a4b-c2ccd82482a2"
          loading="lazy"
          style="border: none; width: 100%; aspect-ratio: 16/9;"
          allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </section>

    <WorkOverlay />
  </>
</Layout>

<style>
  /* ── Hero entrance ── */
  .hero-clip {
    overflow: visible;
    display: block;
  }
  h1 .hero-clip {
    display: inline-block;
  }
  .hero-word {
    display: block;
    transform: translateY(110%);
    opacity: 0;
    animation: hero-rise 0.75s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  h1 .hero-word {
    display: inline-block;
  }
  @keyframes hero-rise {
    to { transform: translateY(0); opacity: 1; }
  }

  /* ── Per-letter hover ── */
  .hero-letter {
    display: inline-block;
    overflow: visible;
    color: var(--color-text-primary);
    -webkit-text-stroke: 2px transparent;
    paint-order: stroke fill;
    transition: color 0.15s ease, -webkit-text-stroke-color 0.15s ease;
    cursor: default;
  }
  .hero-letter:hover {
    color: transparent;
    -webkit-text-stroke-color: var(--color-accent-blue);
    text-shadow: 0 0 20px rgba(0, 200, 255, 0.4), 0 0 60px rgba(0, 200, 255, 0.2), 0 0 100px rgba(0, 200, 255, 0.08);
  }

  /* ── Section nav ── */
  .section-nav-link {
    @apply text-n500 text-xs tracking-widest uppercase transition-colors duration-200 hover:text-n200 py-1;
  }
  .section-nav-link.active {
    color: var(--color-accent-blue);
  }

  /* ── Placeholder pulse ── */
  .placeholder-card, .stagger-card {
    animation: placeholder-pulse 3s ease-in-out infinite;
  }
  @keyframes placeholder-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.6; }
  }

  /* ── Scroll reveal — headings ── */
  .reveal-clip {
    overflow: hidden;
    display: block;
  }
  .reveal-word {
    display: block;
    transform: translateY(110%);
    opacity: 0;
    transition: transform 0.75s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.75s ease;
    transition-delay: var(--reveal-delay, 0ms);
  }
  .is-visible .reveal-word {
    transform: translateY(0);
    opacity: 1;
  }

  /* ── Scroll reveal — cards ── */
  .stagger-card {
    transform: translateY(24px);
    opacity: 0;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s ease;
    transition-delay: var(--card-delay, 0ms);
  }
  .card-grid.is-visible .stagger-card {
    transform: translateY(0);
    opacity: 1;
    animation: none;
  }
</style>

<script>
  function init() {
    // ── Active section nav highlight ──
    const sections = ['featured', 'showreel'];
    const links = document.querySelectorAll('.section-nav-link');

    const navObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            links.forEach((link) => {
              link.classList.toggle(
                'active',
                link.getAttribute('data-section') === entry.target.id
              );
            });
          }
        });
      },
      { rootMargin: '-40% 0px -55% 0px' }
    );

    sections.forEach((id) => {
      const el = document.getElementById(id);
      if (el) navObserver.observe(el);
    });

    // ── Scroll reveal ──
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '0px 0px -10% 0px' }
    );

    document.querySelectorAll('#showreel').forEach((section) => {
      revealObserver.observe(section);
    });

    document.querySelectorAll('.card-grid').forEach((grid) => {
      revealObserver.observe(grid);
    });

    // ── "Work" sticky nav button opens overlay ──
    document.getElementById('nav-work-btn')?.addEventListener('click', () => {
      document.querySelector<HTMLElement>('.work-tab[data-target="0"]')?.click();
    });
  }

  // Run on initial load and after every view transition
  document.addEventListener('astro:page-load', init);
</script>
