---
import Layout from '../layouts/Layout.astro';
import ReelsCarousel from '../components/ReelsCarousel.astro';
import WorkOverlay from '../components/WorkOverlay.astro';

// Order must match WorkOverlay.astro `sections.youtube.ids` / `ytUrls`.
const YOUTUBE_CARDS = [
  { id: '70a7ddcd-705d-42ea-9b36-540249c34b21', line1: 'Not Enough Nelsons', line2: 'Food Truck Challenge' },
  { id: '803e78f8-1c29-40fc-b8b1-2715adad10f3', line1: 'Not Enough Nelsons', line2: 'Back to School' },
  { id: '1a1d745f-a25f-4ff2-9a78-45c95702c5e4', line1: 'Not Enough Nelsons', line2: '17th Birthday' },
  { id: '8cb25f67-087e-4008-9191-5e9bdd4f7c2c', line1: 'Not Enough Nelsons', line2: 'First Cheer' },
  { id: '00f82cdd-20d5-4ec0-91f1-1dc1e409de51', line1: 'Boxing Bullies',     line2: 'Jake Paul Day in the Life' },
  { id: 'c30421a3-69a0-43f8-82e9-21f2ef864e90', line1: 'Shakur Stevenson',   line2: 'Day in the Life' },
];
---

<Layout
  title="Christopher Doubleday | Motion Designer"
  description="Motion designer and video editor creating bold, high-energy content for brands."
  scrollSmooth={true}
>
  <>
    <!-- ==============================
         HERO — name + tagline only
    ============================== -->
    <section class="text-center relative pt-8 pb-4">
      <div class="relative z-10">

        <div class="hero-clip">
          <p class="hero-word font-sans text-sm tracking-widest uppercase mb-8" style="animation-delay: 0ms; color: var(--color-accent-blue);">
            Motion Designer & Video Editor
          </p>
        </div>

        <h1 class="font-display tracking-display text-7xl md:text-9xl text-n200 leading-none mb-6 flex flex-wrap justify-center gap-x-6">
          <span class="hero-clip"><span class="hero-word" style="animation-delay: 80ms"><span class="hero-letter">C</span><span class="hero-letter">h</span><span class="hero-letter">r</span><span class="hero-letter">i</span><span class="hero-letter">s</span></span></span>
          <span class="hero-clip"><span class="hero-word" style="animation-delay: 200ms"><span class="hero-letter">D</span><span class="hero-letter">o</span><span class="hero-letter">u</span><span class="hero-letter">b</span><span class="hero-letter">l</span><span class="hero-letter">e</span><span class="hero-letter">d</span><span class="hero-letter">a</span><span class="hero-letter">y</span></span></span>
        </h1>

        <div class="hero-clip">
          <p class="hero-word mt-4 max-w-xl mx-auto text-n500 text-lg leading-relaxed" style="animation-delay: 380ms">
            Bold visuals. Fast edits. Built for brands that demand attention.
          </p>
        </div>

      </div>
    </section>

    <!-- ==============================
         FEATURED — 3D carousel
    ============================== -->
    <section id="featured" class="py-4">
      <ReelsCarousel />
    </section>

    <!-- ==============================
         STICKY SECTION NAV
    ============================== -->
    <div class="sticky top-[72px] z-10 border-y border-white/5 backdrop-blur-md" style="background: color-mix(in srgb, var(--color-bg-base) 90%, transparent);">
      <nav class="container flex items-center justify-center gap-8 md:gap-16 py-4">
        <a href="#featured"  class="section-nav-link" data-section="featured">Featured</a>
        <a href="#showreel"  class="section-nav-link" data-section="showreel">Featured</a>
        <a href="#youtube"   class="section-nav-link" data-section="youtube">Long Form</a>
        <button             class="section-nav-link" id="nav-work-btn">Work</button>
      </nav>
    </div>

    <!-- ==============================
         SHOWREEL
    ============================== -->
    <section id="showreel" class="py-12 border-t border-white/5">
      <div class="mb-6">
        <div class="reveal-clip"><p class="reveal-word text-sm tracking-widest uppercase mb-3" style="--reveal-delay: 0ms; color: var(--color-accent-blue);">Featured</p></div>
        <div class="reveal-clip"><h2 class="reveal-word font-display tracking-display text-5xl md:text-7xl text-n200" style="--reveal-delay: 120ms">Hawaii 2026</h2></div>
        <div class="reveal-clip"><p class="reveal-word text-n500 mt-4 max-w-lg" style="--reveal-delay: 220ms">A short travel edit shot and cut in Hawaii.</p></div>
      </div>

      <button
        id="showreel-trigger"
        class="editing-card w-full max-w-4xl glow"
        data-section="showreel"
        aria-label="Play Hawaii 2026"
      >
        <iframe
          src="https://iframe.mediadelivery.net/embed/635173/b7da40bf-36c4-45d2-9a4b-c2ccd82482a2?preload=true&responsive=true&muted=true&autoplay=false"
          loading="lazy"
          style="border: none; position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none;"
          tabindex="-1"
          allow="accelerometer; gyroscope; encrypted-media; picture-in-picture"
        ></iframe>
        <div class="editing-play">
          <svg viewBox="0 0 24 24" fill="currentColor" width="48" height="48"><path d="M8 5v14l11-7z"/></svg>
        </div>
      </button>
    </section>

    <!-- ==============================
         YOUTUBE — Long Form Edits
    ============================== -->
    <section id="youtube" class="py-12 border-t border-white/5">
      <div class="mb-6">
        <div class="reveal-clip"><p class="reveal-word text-sm tracking-widest uppercase mb-3" style="--reveal-delay: 0ms; color: var(--color-accent-blue);">YouTube</p></div>
        <div class="reveal-clip"><h2 class="reveal-word font-display tracking-display text-5xl md:text-7xl text-n200" style="--reveal-delay: 120ms">Long Form Edits</h2></div>
        <div class="reveal-clip"><p class="reveal-word text-n500 mt-4 max-w-lg" style="--reveal-delay: 220ms">Episodic vlogs and day-in-the-life cuts — full-length edits built for YouTube.</p></div>
      </div>

      <div class="card-grid youtube-grid">
        {YOUTUBE_CARDS.map((c, i) => (
          <figure class="youtube-card-wrap stagger-card" style={`--card-delay: ${i * 80}ms`}>
            <button
              class="editing-card"
              data-section="youtube"
              data-video-id={c.id}
              aria-label={`Play ${c.line1} — ${c.line2}`}
            >
              <iframe
                src={`https://iframe.mediadelivery.net/embed/635173/${c.id}?preload=true&responsive=true&muted=true&autoplay=false`}
                loading="lazy"
                allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture"
                style="position:absolute;inset:0;width:100%;height:100%;border:none;pointer-events:none;"
                tabindex="-1"
              ></iframe>
              <div class="editing-play">
                <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </button>
            <figcaption class="youtube-card-caption">
              <span class="caption-line1">{c.line1}</span>
              <span class="caption-line2">{c.line2}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>

    <WorkOverlay />
  </>
</Layout>

<style>
  /* ── Hero entrance ── */
  .hero-clip {
    overflow: visible;
    display: block;
  }
  h1 .hero-clip {
    display: inline-block;
  }
  .hero-word {
    display: block;
    transform: translateY(110%);
    opacity: 0;
    animation: hero-rise 0.75s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  h1 .hero-word {
    display: inline-block;
  }
  @keyframes hero-rise {
    to { transform: translateY(0); opacity: 1; }
  }

  /* ── Per-letter hover ── */
  .hero-letter {
    display: inline-block;
    overflow: visible;
    color: var(--color-text-primary);
    -webkit-text-stroke: 2px transparent;
    paint-order: stroke fill;
    transition: color 0.15s ease, -webkit-text-stroke-color 0.15s ease;
    cursor: default;
  }
  .hero-letter:hover {
    color: transparent;
    -webkit-text-stroke-color: var(--color-accent-blue);
    text-shadow: 0 0 20px rgba(0, 200, 255, 0.4), 0 0 60px rgba(0, 200, 255, 0.2), 0 0 100px rgba(0, 200, 255, 0.08);
  }

  /* ── Section nav ── */
  .section-nav-link {
    @apply text-n500 text-xs tracking-widest uppercase transition-colors duration-200 hover:text-n200 py-1;
  }
  .section-nav-link.active {
    color: var(--color-accent-blue);
  }

  /* ── Placeholder pulse ── */
  .placeholder-card, .stagger-card {
    animation: placeholder-pulse 3s ease-in-out infinite;
  }
  @keyframes placeholder-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.6; }
  }

  /* ── Scroll reveal — headings ── */
  .reveal-clip {
    overflow: hidden;
    display: block;
  }
  .reveal-word {
    display: block;
    transform: translateY(110%);
    opacity: 0;
    transition: transform 0.75s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.75s ease;
    transition-delay: var(--reveal-delay, 0ms);
  }
  .is-visible .reveal-word {
    transform: translateY(0);
    opacity: 1;
  }

  /* ── Scroll reveal — cards ── */
  .stagger-card {
    transform: translateY(24px);
    opacity: 0;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s ease;
    transition-delay: var(--card-delay, 0ms);
  }
  .card-grid.is-visible .stagger-card {
    transform: translateY(0);
    opacity: 1;
    animation: none;
  }

  /* ── YouTube / Long Form grid ── */
  .youtube-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px 12px;
    max-width: 880px;
  }
  .youtube-card-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin: 0;
  }
  .youtube-card-caption {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 0 2px;
  }
  .caption-line1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .caption-line2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.25rem;
    letter-spacing: 0.05em;
    color: var(--color-text-primary);
    line-height: 1.1;
  }
  @media (max-width: 640px) {
    .youtube-grid { grid-template-columns: 1fr; max-width: 480px; }
  }
</style>

<script>
  function init() {
    // ── Active section nav highlight ──
    const sections = ['featured', 'showreel', 'youtube'];
    const links = document.querySelectorAll('.section-nav-link');

    const navObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            links.forEach((link) => {
              link.classList.toggle(
                'active',
                link.getAttribute('data-section') === entry.target.id
              );
            });
          }
        });
      },
      { rootMargin: '-40% 0px -55% 0px' }
    );

    sections.forEach((id) => {
      const el = document.getElementById(id);
      if (el) navObserver.observe(el);
    });

    // ── Scroll reveal ──
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '0px 0px -10% 0px' }
    );

    document.querySelectorAll('#showreel, #youtube').forEach((section) => {
      revealObserver.observe(section);
    });

    document.querySelectorAll('.card-grid').forEach((grid) => {
      revealObserver.observe(grid);
    });

    // ── "Work" sticky nav button opens overlay ──
    document.getElementById('nav-work-btn')?.addEventListener('click', () => {
      document.querySelector<HTMLElement>('.work-tab[data-target="0"]')?.click();
    });
  }

  // Run on initial load and after every view transition
  document.addEventListener('astro:page-load', init);
</script>
