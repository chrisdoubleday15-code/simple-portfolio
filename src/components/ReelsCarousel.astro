---
const LIBRARY_ID = '635173';
const videos = [
  // Card 1: Airrack Teaser — a8690e6e-a04f-4b23-b12e-6a85fed5e559
  { id: 'a8690e6e-a04f-4b23-b12e-6a85fed5e559', title: 'Airrack Teaser' },
  // Card 2: Bali Recap — 12af665e-cacc-41ae-929b-81430ede21fa
  { id: '12af665e-cacc-41ae-929b-81430ede21fa', title: 'Bali Recap' },
  // Card 3: Tom Brady Dynasty — 14aa4474-bd9f-420d-8173-458083df44f5
  { id: '14aa4474-bd9f-420d-8173-458083df44f5', title: 'Tom Brady Dynasty' },
  // Card 4: Cruise Recap — 317bcbe4-b3a9-4307-ade6-02f4f1f4de5c
  { id: '317bcbe4-b3a9-4307-ade6-02f4f1f4de5c', title: 'Cruise Recap' },
  // Card 5: Mark Rober Interview — 5629d473-f7ce-49e2-9264-cba3e6fc68f0
  { id: '5629d473-f7ce-49e2-9264-cba3e6fc68f0', title: 'Mark Rober Interview' },
  // Card 6: President's Club — 510b0d07-cd34-4daf-92d4-74bbac5e915b
  { id: '510b0d07-cd34-4daf-92d4-74bbac5e915b', title: "President's Club" },
];
const TOTAL = videos.length;       // 6
const DEG   = 360 / TOTAL;         // 60
---

<div class="carousel-wrapper">
  <div class="carousel-scene">
    <!-- True 3D cylinder: rotate this div to navigate -->
    <div class="carousel-cylinder" id="carousel-cylinder">
      {videos.map((video, i) => (
        <div
          class="carousel-card"
          data-index={i}
          data-video-id={video.id}
          style={`--card-angle: ${i * DEG}deg`}
        >
          <div class="card-face">
            <!-- iframe injected by JS only when card is active -->
          </div>
        </div>
      ))}
    </div>

    <!-- Arrow controls positioned relative to scene -->
    <button class="carousel-arrow left"  id="carousel-prev" aria-label="Previous">&#10094;</button>
    <button class="carousel-arrow right" id="carousel-next" aria-label="Next">&#10095;</button>
  </div>

  <!-- Dot indicators -->
  <div class="carousel-dots" id="carousel-dots">
    {videos.map((_, i) => (
      <button class="carousel-dot" data-dot={i} aria-label={`Go to clip ${i + 1}`} />
    ))}
  </div>

  <!-- Global mute button — centered below dots -->
  <button class="carousel-mute" id="carousel-mute" aria-label="Toggle mute"></button>
</div>

<style>
  .carousel-wrapper {
    /*
     * ── Hexagonal cylinder geometry ──────────────────────────────
     * For a true regular hexagon (6 cards, 60deg intervals):
     *   translateZ = cardWidth / (2 * tan(π/6)) = cardWidth * 0.866
     *   perspective ≈ 3 × translateZ  (natural-looking depth)
     *
     * With --card-w: 240px →  240 * 0.866 = 208px  →  perspective = 624px
     * Adjust --card-w and recompute the other two to retune.
     * ─────────────────────────────────────────────────────────────
     */
    --card-w: 240px;
    --card-h: 427px;               /* exact 9:16 */
    --carousel-radius: 270px;      /* > card-w * 0.866 = gap between cards */
    --carousel-perspective: 810px; /* ≈ 3 × carousel-radius */

    position: relative;
    width: 100%;
    overflow: visible;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    user-select: none;
  }

  /* 3D stage — perspective applied here */
  .carousel-scene {
    position: relative;
    width: 100%;
    height: 640px;
    perspective: var(--carousel-perspective);
    overflow: visible;
  }

  /* The cylinder — rotates as a whole unit */
  .carousel-cylinder {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    transform-style: preserve-3d;
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Individual cards — fixed positions on the cylinder surface */
  .carousel-card {
    position: absolute;
    width: var(--card-w);
    height: var(--card-h);
    /* Center each card on the cylinder origin before 3D transform */
    top:  calc(var(--card-h) / -2);
    left: calc(var(--card-w) / -2);
    /* Initial position: baked angle + radius push */
    transform: rotateY(var(--card-angle, 0deg)) translateZ(var(--carousel-radius, 320px));
    transform-style: preserve-3d;
    backface-visibility: visible;
    transition: transform 400ms ease-in-out, opacity 400ms ease-in-out, filter 400ms ease-in-out;
  }

  /* Card face — holds the iframe */
  .card-face {
    position: relative;
    width: 100%;
    height: 100%;
    background: var(--color-bg-surface);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 4px;
    overflow: hidden;
  }

  .card-face iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  /* Global mute button — pill below dots */
  .carousel-mute {
    width: 48px;
    height: 24px;
    border-radius: 999px;
    background: rgba(13, 13, 31, 0.65);
    border: 1.5px solid rgba(0, 200, 255, 0.4);
    color: rgba(0, 200, 255, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    backdrop-filter: blur(6px);
    padding: 0;
    margin-top: 12px;
  }
  .carousel-mute:hover {
    border-color: var(--color-accent-blue);
    color: var(--color-accent-blue);
  }
  .carousel-mute svg {
    width: 10px;
    height: 10px;
    fill: currentColor;
    pointer-events: none;
  }

  /* Block native PiP on non-active cards */
  .carousel-card:not([data-offset="0"]) video { pointer-events: none; }

  /* Depth blur by distance from center */
  .carousel-card[data-offset="0"]                                      { filter: blur(0px);   }
  .carousel-card[data-offset="1"],  .carousel-card[data-offset="-1"]  { filter: blur(3px); }
  .carousel-card[data-offset="2"],  .carousel-card[data-offset="-2"]  { filter: blur(4px); }

  /* Center card: layered glow emanating from the edge */
  .carousel-card[data-offset="0"] .card-face {
    border-color: var(--color-accent-blue);
    animation: card-glow-pulse 3.5s ease-in-out infinite;
  }

  @keyframes card-glow-pulse {
    0%, 100% {
      box-shadow:
        0 0  6px 1px  rgba(0, 200, 255, 0.85),
        0 0 20px 4px  rgba(0, 200, 255, 0.30),
        0 0 22px 3px  rgba(0, 200, 255, 0.15);
    }
    50% {
      box-shadow:
        0 0  6px 1px  rgba(0, 200, 255, 0.85),
        0 0 20px 4px  rgba(0, 200, 255, 0.30),
        0 0 22px 3px  rgba(0, 200, 255, 0.08);
    }
  }

  /* Arrow controls */
  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(13, 13, 31, 0.65);
    border: 1.5px solid var(--color-accent-blue);
    color: var(--color-accent-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1;
    transition: background 0.2s, color 0.2s;
    backdrop-filter: blur(6px);
    z-index: 10;
  }
  .carousel-arrow:hover {
    background: var(--color-accent-blue);
    color: #000;
  }
  .carousel-arrow.left  { left:  0; }
  .carousel-arrow.right { right: 0; }

  /* Dot indicators */
  .carousel-dots {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-top: 20px; /* front card visual height ~= scene height, minimal overflow */
  }
  .carousel-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #444;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    padding: 0;
  }
  .carousel-dot.active {
    background: var(--color-accent-blue);
    transform: scale(1.4);
  }
</style>

<script>
  function initCarousel() {
    const TOTAL = 6;
    const DEG   = 60; // 360 / 6

    let active   = 0;
    let rotation = 0; // cumulative degrees — never reset, drives cylinder transform
    let muted    = true;

    const ICON_MUTED = `<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="width:16px;height:16px;"><path d="M16.5 12A4.5 4.5 0 0 0 14 7.97v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3 3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06a8.99 8.99 0 0 0 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4 9.91 6.09 12 8.18V4z"/></svg>`;
    const ICON_SOUND = `<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="width:16px;height:16px;"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0 0 14 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>`;

    const cylinder = document.getElementById('carousel-cylinder') as HTMLElement | null;
    if (!cylinder) return;

    // Read radius from CSS so --carousel-radius is the single source of truth
    const wrapper = cylinder.closest<HTMLElement>('.carousel-wrapper')!;
    const RADIUS  = parseInt(getComputedStyle(wrapper).getPropertyValue('--carousel-radius')) || 320;

    const cards = Array.from(cylinder.querySelectorAll<HTMLElement>('.carousel-card'));
    const dots  = Array.from(document.querySelectorAll<HTMLElement>('.carousel-dot'));
    const prev  = document.getElementById('carousel-prev');
    const next  = document.getElementById('carousel-next');

    /** Returns signed offset (-3..3) of card[index] relative to active */
    function getOffset(index: number): number {
      let off = ((index - active) % TOTAL + TOTAL) % TOTAL;
      if (off > TOTAL / 2) off -= TOTAL;
      return off;
    }

    function render() {
      if (cylinder) cylinder.style.transform = `rotateY(${rotation}deg)`;

      cards.forEach((card, i) => {
        const off = getOffset(i);
        const abs = Math.abs(off);

        // Opacity + scale by distance from center
        let opacity: number, scale: number;
        if      (abs === 0) { opacity = 1;    scale = 1;    }
        else if (abs === 1) { opacity = 0.5;  scale = 0.9;  }
        else if (abs === 2) { opacity = 0.2;  scale = 0.75; }
        else                { opacity = 0;    scale = 0.5;  } // 180deg — hidden by backface-visibility

        // Positional transform (fixed angle + radius) + scale
        card.style.transform = `rotateY(${i * DEG}deg) translateZ(${RADIUS}px) scale(${scale})`;
        card.style.opacity   = String(opacity);
        // data-offset drives the red glow CSS rule
        card.dataset.offset  = String(off);
      });

      dots.forEach((dot, i) => dot.classList.toggle('active', i === active));
    }

    const LIBRARY_ID = '635173';

    function createIframe(id: string, autoplay: boolean): HTMLIFrameElement {
      const iframe = document.createElement('iframe');
      iframe.src = autoplay
        ? `https://player.mediadelivery.net/embed/${LIBRARY_ID}/${id}?autoplay=true&loop=true&muted=${muted}&preload=true&controls=false&responsive=true`
        : `https://player.mediadelivery.net/embed/${LIBRARY_ID}/${id}?autoplay=false&muted=true&preload=true&controls=false&responsive=true`;
      iframe.allow           = 'accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.setAttribute('disablepictureinpicture', '');
      iframe.style.cssText   = 'width:100%;height:100%;border:none;display:block;opacity:0;transition:opacity 400ms ease;';
      iframe.addEventListener('load', () => { iframe.style.opacity = '1'; }, { once: true });
      return iframe;
    }

    // Remove only the autoplay overlay — base iframe stays, showing first frame
    function pauseCard(card: HTMLElement) {
      card.querySelector('.iframe-active')?.remove();
    }

    // Layer an autoplay iframe on top of the stable base iframe
    function playCard(card: HTMLElement) {
      card.querySelector('.iframe-active')?.remove();
      const face   = card.querySelector<HTMLElement>('.card-face')!;
      const iframe = createIframe(card.dataset.videoId!, true);
      iframe.classList.add('iframe-active');
      iframe.style.position = 'absolute';
      iframe.style.inset    = '0';
      face.appendChild(iframe);
    }

    const muteBtn = document.getElementById('carousel-mute') as HTMLElement | null;

    function updateMuteBtn() {
      if (!muteBtn) return;
      muteBtn.innerHTML = muted ? ICON_MUTED : ICON_SOUND;
      muteBtn.setAttribute('aria-label', muted ? 'Unmute' : 'Mute');
    }

    muteBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      muted = !muted;
      updateMuteBtn();
      playCard(cards[active]); // rebuild active iframe with new mute state
    });

    function advance(dir: number) {
      pauseCard(cards[active]);
      rotation -= dir * DEG; // right (+1) = -60deg, left (-1) = +60deg
      active    = ((active + dir) % TOTAL + TOTAL) % TOTAL;
      render();
      playCard(cards[active]);
    }

    prev?.addEventListener('click', () => advance(-1));
    next?.addEventListener('click', () => advance(1));

    function handleKeydown(e: KeyboardEvent) {
      const tag = (e.target as Element).tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA') return;
      if (e.key === 'ArrowLeft')  advance(-1);
      if (e.key === 'ArrowRight') advance(1);
    }
    document.addEventListener('keydown', handleKeydown);
    document.addEventListener('astro:before-swap', () => {
      document.removeEventListener('keydown', handleKeydown);
    }, { once: true });
    dots.forEach((dot, i) => dot.addEventListener('click', () => {
      if (i === active) return;
      let delta = i - active;
      if (delta >  TOTAL / 2) delta -= TOTAL; // take shortest arc
      if (delta < -TOTAL / 2) delta += TOTAL;
      pauseCard(cards[active]);
      rotation -= delta * DEG;
      active    = i;
      render();
      playCard(cards[active]);
    }));

    // Drag / swipe
    let dragStart = 0;
    let dragging  = false;
    const THRESHOLD = 60;
    const scene = cylinder.closest<HTMLElement>('.carousel-scene')!;

    scene.addEventListener('pointerdown', (e) => {
      const target = e.target as Element;
      if (target.closest('.carousel-arrow') || target.closest('.carousel-dot') || target.closest('#carousel-mute')) return;
      dragging  = true;
      dragStart = e.clientX;
      scene.setPointerCapture(e.pointerId);
    });

    scene.addEventListener('pointerup', (e) => {
      if (!dragging) return;
      dragging = false;
      const delta = e.clientX - dragStart;
      if (Math.abs(delta) > THRESHOLD) advance(delta < 0 ? 1 : -1);
    });

    scene.addEventListener('pointercancel', () => { dragging = false; });

    // Base iframes: permanent, never reloaded, always show first frame
    cards.forEach(card => {
      card.querySelector<HTMLElement>('.card-face')!
        .appendChild(createIframe(card.dataset.videoId!, false));
    });

    render();
    playCard(cards[active]); // overlay autoplay iframe on active card
    updateMuteBtn();
  }

  document.addEventListener('astro:page-load', initCarousel);
</script>
