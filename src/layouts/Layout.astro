---
import {ClientRouter} from 'astro:transitions';
import {cn} from "../lib/utils";
import '@/styles/globals.css'

import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

import {SITE} from '@/config';

interface Props {
    title?: string;
    scrollSmooth: boolean;
    description?: string;
    tags?: string[];
    author?: string;
    imageOg?: string;
    canonicalURL?: string;
}

const {
    title = SITE.title,
    description = SITE.description,
    tags = SITE.tags,
    author = SITE.author,
    scrollSmooth,
    canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
    imageOg = SITE.ogImage,
} = Astro.props;
---

<!doctype html>
<html lang={SITE.lang ?? "en"} class={cn("dark", {"scroll-smooth": scrollSmooth})}>
<head>
    <meta name="msapplication-TileColor" content="#000000"/>
    <meta name="viewport" content="width=device-width"/>
    <meta charset="UTF-8"/>
    <meta name="generator" content={Astro.generator}/>

    <meta name="title" content={title}/>
    <meta name="description" content={description}/>
    <meta name="keywords" content={tags.join(', ')}/>
    <meta name="author" content={author}/>
    <link rel="sitemap" href="/sitemap-index.xml"/>
    <link rel="icon" href={SITE.favicon}/>
    <link rel="canonical" href={canonicalURL}/>

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title}/>
    <meta property="og:description" content={description}/>
    <meta property="og:url" content={canonicalURL}/>
    <meta property="og:image" content={imageOg}/>
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image"/>
    <meta property="twitter:url" content={canonicalURL}/>
    <meta property="twitter:title" content={title}/>
    <meta property="twitter:description" content={description}/>
    <meta property="twitter:image" content={imageOg}/>

    <title>{title}</title>
    <ClientRouter/>
</head>
<body class="antialiased text-n200 font-sans w-full min-h-screen flex flex-col" style="background: var(--color-bg-base);">
<div id="film-grain" style="position:fixed;inset:0;z-index:0;background-image:url('/images/film-grain.png');background-size:100vw 100vh;background-repeat:repeat;opacity:0.03;pointer-events:none;mix-blend-mode:screen;"></div>
<Navbar style="position:relative;z-index:1;"/>
<main class="container pt-16 pb-12 flex flex-col gap-8 flex-grow" role="main" id="top" style="position:relative;z-index:1;">
  <slot/>
</main>
<Footer/>

<script>
  function initGrain() {
    const overlay = document.getElementById('film-grain');
    if (!overlay) return;
    window.addEventListener('scroll', () => {
      overlay.style.backgroundPositionY = `${window.scrollY * -0.1}px`;
    }, { passive: true });
  }
  document.addEventListener('astro:page-load', initGrain);
</script>
</body>
</html>
